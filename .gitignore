# ===========================================
# User Projects (contains real business data)
# ===========================================
projects/

# ===========================================
# Private one-off generation scripts — PRIVATE, not for the repo
# -------------------------------------------------------
# Ad-hoc scripts written to generate content for a specific project under
# projects/ (they embed business copy, names, strategy, brand assets).
# These are personal working files, NOT reusable toolkit code.
#
# Root-anchored (leading /) so legit toolkit docs like
# skills/generate-*/SKILL.md stay tracked.
#
# Real toolkit code lives in subdirs (gemini/, workflows/, openrouter/, skills/);
# per-project generation scripts belong under projects/ (already ignored). So ANY
# .cjs/.ts sitting at the repo ROOT is a one-off (agent- or human-authored) that may
# embed private project content — never commit it. If you ever add a genuinely shared
# root script, force it in with:  git add -f <file>
# ===========================================
/*.cjs
/*.ts

# ===========================================
# Generated Content Outputs (can be large)
# ===========================================

# Any folder containing "output" in the name
*output/
*output*/
output-*/
*-output/

# Specific output folders
examples/content-output/
tests/results/
test-output/
gemini/output/

