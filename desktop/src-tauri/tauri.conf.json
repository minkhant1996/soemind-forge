{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoeMind Forge",
  "version": "0.1.0",
  "identifier": "com.soemind.forge",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SoeMind Forge",
        "width": 980,
        "height": 720,
        "minWidth": 780,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Installer and launcher for the SoeMind Forge AI content studio",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
